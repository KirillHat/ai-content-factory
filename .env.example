# =====================================================================
# AI Content Factory — environment configuration
# Copy to .env and fill in your real values. .env is gitignored.
# =====================================================================

# ---- API tokens (REQUIRED for live operation) ----
NOTION_TOKEN=
OPENAI_API_KEY=
MAKE_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
BUFFER_TOKEN=

# ---- Make.com workspace ----
MAKE_ZONE=us2
MAKE_TEAM_ID=

# ---- Make.com connection IDs (per-workspace integration IDs) ----
# Find via GET https://{zone}.make.com/api/v2/connections after auth
MAKE_NOTION_CONN=
MAKE_OPENAI_CONN=
MAKE_TELEGRAM_CONN=
MAKE_SLACK_CONN=

# ---- Notion database IDs ----
# After running `python -m scripts.create_notion_dbs`, copy IDs here
NOTION_TOOLS_DB=
NOTION_STACKS_DB=

# ---- Notion parent page (used only by scripts/create_notion_dbs.py once) ----
NOTION_PARENT_PAGE_ID=

# ---- Telegram channel ----
# Numeric ID with -100 prefix (use @username_to_id_bot to find it) OR @handle
TELEGRAM_CHANNEL=
TELEGRAM_CHANNEL_USERNAME=@your_channel

# ---- Buffer profile IDs (one per platform) ----
# GET https://api.bufferapp.com/1/profiles.json after Buffer auth
BUFFER_IG_PROFILE=
BUFFER_LINKEDIN_RU_PROFILE=
BUFFER_LINKEDIN_EN_PROFILE=
BUFFER_PINTEREST_PROFILE=

# ---- Brand customization ----
# Used in card footers and hashtag generation
BRAND_NAME=AI Content Factory
BRAND_TAGLINE=Simple AI tools for small business growth

# ---- Backup scheduler (scripts/backup_blueprints.py) ----
# Comma-separated list of Make scenario IDs to back up weekly
MAKE_SCENARIO_IDS=
